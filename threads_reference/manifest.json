{
   "action": {
      "default_icon": "icons/icon_128.png",
      "default_title": "__MSG_name__"
   },
   "background": {
      "service_worker": "js/sw.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "css": [ "css/content.css" ],
      "js": [ "js/cs.js" ],
      "matches": [ "https://*.threads.com/*", "https://*.threads.net/*" ]
   } ],
   "default_locale": "en",
   "description": "__MSG_description__",
   "host_permissions": [ "https://www.threads.com/*", "https://i.instagram.com/*", "https://www.instagram.com/*", "https://*.cdninstagram.com/*", "https://*.fbcdn.net/*" ],
   "icons": {
      "128": "icons/icon_128.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_name__",
   "options_ui": {
      "open_in_tab": false,
      "page": "/html/options.html"
   },
   "permissions": [ "downloads", "declarativeNetRequestWithHostAccess", "cookies", "storage", "webRequest", "tabs" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.1.5"
}
